{
  "name": "pathcipher-site",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind CSS build for the Pathcipher public site.",
  "scripts": {
    "build:css": "tailwindcss -i ./static/src/tailwind.css -o ./static/css/tailwind.build.css --minify",
    "watch:css": "tailwindcss -i ./static/src/tailwind.css -o ./static/css/tailwind.build.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "tailwindcss": "^3.4.14"
  }
}
