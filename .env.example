# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# --- Django ---
# Generate one with:  python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_DEBUG=True
# Comma-separated. In prod set your real domain(s).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated https origins for CSRF in prod, e.g. https://puzzle.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Public site ---
WAGTAIL_SITE_NAME=Pathcipher Events
# Base URL used by Wagtail for absolute links / sitemap
WAGTAILADMIN_BASE_URL=http://localhost:8000

# --- Database (Postgres) ---
# In dev, if DATABASE_URL is unset, settings fall back to sqlite.
# In prod this MUST be set. Docker Compose builds it from the pieces below.
POSTGRES_DB=puzzle
POSTGRES_USER=puzzle
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Optional explicit override; if set, takes precedence over the pieces above.
# DATABASE_URL=postgres://puzzle:change-me@db:5432/puzzle

# --- TLS / certbot (prod only) ---
DOMAIN=puzzle.example.com
CERTBOT_EMAIL=you@example.com

# --- Image / Watchtower (prod only) ---
# Pin a specific published tag instead of always tracking :latest, e.g.
# ghcr.io/pathcipher/website:sha-<commit>. Leave unset to use :latest.
# DOCKER_IMAGE=ghcr.io/pathcipher/website:latest
# How often Watchtower checks GHCR for a new image, in seconds.
WATCHTOWER_POLL_INTERVAL=300
